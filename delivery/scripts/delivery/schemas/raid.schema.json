{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nopilot.co/schemas/delivery/raid.json",
  "title": "Delivery — RAID register",
  "description": "Risks / Assumptions / Issues / Dependencies — first-class open items (Bible §8 shape).",
  "type": "object",
  "required": ["engagement", "items"],
  "properties": {
    "engagement": { "type": "string", "minLength": 1 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "title", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": ["risk", "assumption", "issue", "dependency"]
          },
          "title": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "status": { "type": "string", "enum": ["open", "resolved"] },
          "owner": { "type": "string" },
          "notes": { "type": "string" },
          "raised_at": { "type": "string" },
          "resolved_at": { "type": "string" },
          "resolution": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
