{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nopilot.co/schemas/delivery/plan.json",
  "title": "Delivery — engagement plan",
  "description": "Structured delivery plan: swimlanes, phases, resourcing, contingency. Caller-supplied; CLI derives rollups.",
  "type": "object",
  "required": ["engagement", "phases"],
  "properties": {
    "engagement": { "type": "string", "minLength": 1 },
    "objective": { "type": "string" },
    "swimlanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "owner_role": { "type": "string" },
          "owner_studio": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "order", "duration_days"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "minimum": 1 },
          "swimlane": { "type": "string" },
          "entry": { "type": "array", "items": { "type": "string" } },
          "exit": { "type": "array", "items": { "type": "string" } },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "duration_days": { "type": "number", "exclusiveMinimum": 0 },
          "buffer_days": { "type": "number", "minimum": 0 },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "resourcing": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["role", "days"],
              "properties": {
                "role": { "type": "string", "minLength": 1 },
                "days": { "type": "number", "exclusiveMinimum": 0 }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "contingency": {
      "type": "object",
      "properties": {
        "pool_days": { "type": "number", "minimum": 0 },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "rollups": { "type": "object" },
    "provenance": { "type": "object" }
  },
  "additionalProperties": true
}
