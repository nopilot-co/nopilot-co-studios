        { "type": "text", "content": "Brand name: framework", "region": "center", "role": "primary", "enter": "fade-up" },
        { "type": "shape", "content": "accent-rule", "region": "lower-third", "role": "accent", "enter": "wipe-left" }
      ]
    },
    {
      "id": "criteria",
      "duration": 6,
      "narration": "Any candidate name must satisfy five things, in order of priority.",
      "transition": "slide",
      "layers": [
        { "type": "text", "content": "The criteria", "region": "top", "role": "primary", "enter": "fade" },
        { "type": "chart", "chart": "kpi", "data": 5, "region": "left", "role": "accent", "enter": "fade-up" },
        { "type": "text", "content": "things a name must satisfy, in priority order", "region": "right", "role": "secondary", "enter": "fade-up" }
      ]
    },
    {
      "id": "categories",
      "duration": 6,
      "narration": "The exploration produced four families of names — each with its own buyer signal.",
      "transition": "fade",
      "layers": [
        { "type": "text", "content": "The four categories", "region": "top", "role": "primary", "enter": "fade" },
        { "type": "chart", "chart": "bar", "region": "center", "role": "accent", "enter": "fade-up",
          "data": [
            { "label": "Industrial", "value": 4 },
            { "label": "Technical", "value": 6 },
            { "label": "Allegorical", "value": 5 },
            { "label": "Literal", "value": 3 }
          ] }
      ]
    },
    {
      "id": "close",
      "duration": 4,
      "narration": "Pick a category. Narrow to two or three options inside it. Test.",
      "transition": "cut",
      "layers": [
        { "type": "text", "content": "Next: pick a category, then test", "region": "center", "role": "primary", "enter": "fade-up" },
        { "type": "image", "content": "assets/logo.svg", "region": "lower-third", "role": "secondary", "enter": "fade" }
      ]
    }
  ]
