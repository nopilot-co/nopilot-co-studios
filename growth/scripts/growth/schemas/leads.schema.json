{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nopilot.co/schemas/growth/leads.json",
  "title": "Growth — lead list",
  "type": "object",
  "required": ["engagement", "icp", "leads"],
  "properties": {
    "engagement": { "type": "string", "minLength": 1 },
    "icp": { "type": "string" },
    "criteria": { "type": "array", "items": { "type": "string" } },
    "leads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["company", "fit"],
        "properties": {
          "company": { "type": "string", "minLength": 1 },
          "signals": {
            "type": "object",
            "properties": {
              "matched": { "type": "array", "items": { "type": "string" } },
              "missing": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          },
          "fit": { "type": "string", "enum": ["low", "medium", "high"] },
          "owner": { "type": "string" },
          "source": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "rollups": { "type": "object" },
    "provenance": { "type": "object" }
  },
  "additionalProperties": true
}
