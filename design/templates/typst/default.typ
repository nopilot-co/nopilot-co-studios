// design-studio default Typst template.
//
// Quarto's Typst format consumes _brand.yml automatically — most brands need
// nothing here. Drop a copy of this file in <brand>/typst-overrides.typ only
// when you need behaviour beyond what _brand.yml expresses (e.g. running
// headers/footers, custom title pages, multi-column layouts).
//
// Example overrides:
//
// #set page(
//   header: align(right)[#image("assets/logo.svg", width: 80pt)],
//   footer: align(center)[#counter(page).display()],
// )
//
// #set par(justify: true)
