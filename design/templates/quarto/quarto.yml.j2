# Auto-generated by studio.render — do not edit by hand.
# Materialized per-render in <session>/.tmp/_quarto.yml

project:
  type: default

brand: _brand.yml

# Component bridge: maps `::: <class>` divs to Typst component calls (HTML keeps
# the div; CSS styles it). See components.lua / _components.css / the typst preamble.
filters:
  - components.lua

format:
{% for fmt in formats %}
{%- if fmt == "pdf" %}
  typst:
    toc: false
    fontsize: 11pt
    margin:
      x: 1in
      y: 1in
    # Token dict (#let ds) + component functions (#let c_*) + capped header logo
    # (issue #2), injected at the top of the body scope so `#c_<class>[ ... ]`
    # calls resolve. include-before-body TEXT keeps them in top-level scope.
    include-before-body:
      text: |
{{ typst_preamble | indent(8, true) }}
{%- elif fmt == "pptx" %}
  pptx:
{%- if has_pptx_reference %}
    reference-doc: reference.pptx
{%- endif %}
    incremental: false
{%- elif fmt == "html" %}
  html:
    toc: true
    toc-location: left
    embed-resources: true
    theme: default
    css:
      - _components.css
{%- if css_override %}
      - css/overrides.css
{%- endif %}
{%- if html_header %}
    include-before-body:
      - {{ html_header }}
{%- endif %}
{%- elif fmt == "revealjs" %}
  revealjs:
    theme: default
    slide-number: true
    incremental: false
{%- if css_override %}
    css: css/overrides.css
{%- endif %}
{%- endif %}
{% endfor %}
