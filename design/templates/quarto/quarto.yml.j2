# Auto-generated by studio.render — do not edit by hand.
# Materialized per-render in <session>/.tmp/_quarto.yml

project:
  type: default

brand: _brand.yml

format:
{% for fmt in formats %}
{%- if fmt == "pdf" %}
  typst:
    toc: false
    fontsize: 11pt
    margin:
      x: 1in
      y: 1in
{%- if logo %}
    # Cap the brand header logo and keep it inside the top margin so it never
    # overlaps body text on continuation pages (issue #2). This re-sets the page
    # background after Quarto's brand layer (whose default 1.5in logo is too tall
    # for square/portrait lockups); body still starts at the 1in top margin.
    include-before-body:
      text: |
        #set page(background: align(left + top, box(inset: 0.4in, image("{{ logo }}", height: 0.4in))))
{%- endif %}
{%- elif fmt == "pptx" %}
  pptx:
{%- if has_pptx_reference %}
    reference-doc: reference.pptx
{%- endif %}
    incremental: false
{%- elif fmt == "html" %}
  html:
    toc: true
    toc-location: left
    embed-resources: true
    theme: default
{%- if css_override %}
    css: css/overrides.css
{%- endif %}
{%- elif fmt == "revealjs" %}
  revealjs:
    theme: default
    slide-number: true
    incremental: false
{%- if css_override %}
    css: css/overrides.css
{%- endif %}
{%- endif %}
{% endfor %}
