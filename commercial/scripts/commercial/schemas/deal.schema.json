{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nopilot.co/schemas/commercial/deal.json",
  "title": "Commercial — deal under review",
  "description": "A deal proposed for review. Roles + rates + days; totals derived.",
  "type": "object",
  "required": ["deal", "lines"],
  "properties": {
    "deal": { "type": "string", "minLength": 1 },
    "client": { "type": "string" },
    "engagement": { "type": "string" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "rate", "days"],
        "properties": {
          "role": { "type": "string", "minLength": 1 },
          "rate": { "type": "number", "exclusiveMinimum": 0 },
          "days": { "type": "number", "exclusiveMinimum": 0 },
          "note": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
