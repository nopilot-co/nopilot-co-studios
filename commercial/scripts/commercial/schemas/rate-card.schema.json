{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nopilot.co/schemas/commercial/rate-card.json",
  "title": "Commercial — rate card",
  "description": "Org-wide rate card: skill → revenue rate and internal cost.",
  "type": "object",
  "required": ["currency", "unit", "roles"],
  "properties": {
    "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
    "unit": { "type": "string", "enum": ["day", "hour"] },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "rate"],
        "properties": {
          "role": { "type": "string", "minLength": 1 },
          "rate": { "type": "number", "exclusiveMinimum": 0 },
          "cost": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
